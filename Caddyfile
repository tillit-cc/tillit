# TilliT Self-Hosted - Caddy Reverse Proxy Configuration
#
# This Caddyfile configures Caddy as a reverse proxy for TilliT
# with automatic HTTPS via Let's Encrypt using DNS-01 challenge.
#
# The DNS-01 challenge is performed via the cloud worker's ACME-DNS API
# (worker.tillit.cc).
#
# Required environment variables:
#   DOMAIN           - The domain (e.g., my-box.tillit.cc)
#   HTTPS_PORT       - HTTPS port (default: 443)
#   HTTP_PORT        - HTTP port (default: 80)
#   ACMEDNS_SERVER   - ACME-DNS server URL (e.g., https://worker.tillit.cc/acmedns)
#   ACMEDNS_USERNAME - ACME-DNS username (same as CLOUD_ID)
#   ACMEDNS_PASSWORD - ACME-DNS password (same as CLOUD_TOKEN)
#   ACMEDNS_SUBDOMAIN - ACME-DNS subdomain (same as CLOUD_ID)

{
	# Global options
	admin off

	# ACME configuration
	acme_ca https://acme-v02.api.letsencrypt.org/directory
}

# HTTPS on configured port (default 443)
{$DOMAIN}:{$HTTPS_PORT:443} {
	# TLS configuration with ACME-DNS
	tls {
		dns acmedns {
			server_url {$ACMEDNS_SERVER}
			username {$ACMEDNS_USERNAME}
			password {$ACMEDNS_PASSWORD}
			subdomain {$ACMEDNS_SUBDOMAIN}
		}
	}

	# Reverse proxy to TilliT backend
	reverse_proxy tillit:3000 {
		# WebSocket support is automatic in Caddy 2
		header_up X-Forwarded-Proto {scheme}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-Host {host}
	}

	# Logs
	log {
		output stderr
		format console
	}
}

# HTTP on configured port (default 80)
# Serves as fallback and redirects to HTTPS
:{$HTTP_PORT:80} {
	# Redirect to HTTPS if accessing via domain
	@hasdomain host {$DOMAIN}
	handle @hasdomain {
		redir https://{$DOMAIN}:{$HTTPS_PORT:443}{uri} permanent
	}

	# For IP-based access, proxy directly to TilliT
	handle {
		reverse_proxy tillit:3000 {
			header_up X-Forwarded-Proto http
			header_up X-Real-IP {remote_host}
		}
	}
}