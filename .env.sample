# App config
APP_ENV=development
APP_NAME="tillit"
APP_URL=http://localhost:3000
APP_PORT=3000

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=tillit
DB_USER=root
DB_PASSWORD=

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_USER=
REDIS_PASSWORD=
REDIS_KEY_PREFIX=tillit:

# JWT
JWT_ALGORITHM=RS256
PUBLIC_KEY_PATH=./keys/public.pem
PRIVATE_KEY_PATH=./keys/private.pem
JWT_EXPIRES_IN=7d

# Expo Push Notifications
# Get your access token from https://expo.dev/accounts/[account]/settings/access-tokens
EXPO_ACCESS_TOKEN=

# CORS (set to specific origin in production, e.g. https://app.tillit.cc)
# Default: true (allows all origins)
# CORS_ORIGIN=https://app.tillit.cc

# Socket.IO ack timeout (milliseconds, default: 5000 = 5 seconds)
ACK_TIMEOUT_MS=5000

# Cleanup intervals (milliseconds, default: 3600000 = 1 hour)
PENDING_CLEANUP_INTERVAL_MS=3600000
MEDIA_CLEANUP_INTERVAL_MS=3600000

# Persistent Media Storage (for offline message support)
# Directory where encrypted media blobs are stored
MEDIA_STORAGE_DIR=./data/media
# Maximum file size in bytes (default: 10MB)
MEDIA_MAX_SIZE=10485760
# Number of days to retain media before cleanup (default: 30)
MEDIA_RETENTION_DAYS=30
